# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL="Portfolio Contact <contact@yourdomain.com>"
CONTACT_TO_EMAIL=you@example.com

# Google Ads API setup for local campaign management.
# GOOGLE_ADS_CUSTOMER_ID must be set explicitly so campaigns are not created in
# the wrong account. Use 1099427521 when repurposing the existing promo account.
GOOGLE_ADS_MANAGER_CUSTOMER_ID=2496704694
GOOGLE_ADS_CUSTOMER_ID=1099427521
GOOGLE_ADS_CONFIG_PATH=/Users/duncananderson/.codex/google-ads.yaml
GOOGLE_ADS_DAILY_BUDGET_CAD=20.00
GOOGLE_ADS_MAX_CPC_CAD=3.00
GOOGLE_ADS_EXPANDED_MAX_CPC_CAD=6.00
GOOGLE_ADS_AI_CONSULTING_LANDING_URL=https://www.duncananderson.ca/en/ai-workflow-audit

# Public Google tag / Google Ads conversion tracking. The send_to value usually
# has the shape AW-XXXXXXXXXX/YYYYYYYYYYYYYYYYYYY.
NEXT_PUBLIC_GOOGLE_TAG_ID=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_SEND_TO=
