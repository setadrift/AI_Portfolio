# --- Public site ---
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL="Portfolio Contact <contact@yourdomain.com>"
CONTACT_TO_EMAIL=you@example.com

# --- Client portal (/portal/*) ---
# Random 32+ char hex string used to sign session cookies. Generate with:
#   openssl rand -hex 32
PORTAL_SESSION_SECRET=

# Either set PORTAL_USERS as a JSON array of {username,password,client}.
# Use client "admin" for Duncan's private admin tools.
# PORTAL_USERS=[{"username":"duncan","password":"...","client":"admin"},{"username":"gabby","password":"...","client":"ttg"}]
# Or use the simple single-user fallback (creates a "ttg" user with this password):
PORTAL_PASSWORD=
# Optional local fallback for Duncan's admin dashboard. Username is "duncan".
ADMIN_PORTAL_PASSWORD=
# Enable server-side admin lead scans outside local development.
# Production scans also require BLOB_READ_WRITE_TOKEN so the portal can publish results.
LEAD_SCAN_ENABLED=
# Created by linking the private Vercel Blob store used by the admin leads page.
BLOB_READ_WRITE_TOKEN=

# --- TTG WordPress publishing (used by /portal/ttg/publish) ---
TTG_WP_BASE_URL=https://traumatherapygroup.com
TTG_WP_USERNAME=gabevans
TTG_WP_APP_PASSWORD=

# --- Google Gemini / Imagen 4 (used for blog image generation) ---
# Get a key at https://aistudio.google.com/app/apikey (billing must be enabled for Imagen)
GEMINI_API_KEY=
