# --- Public site ---
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL="Portfolio Contact <contact@yourdomain.com>"
CONTACT_TO_EMAIL=you@example.com

# Google Ads API setup for local campaign management.
# GOOGLE_ADS_CUSTOMER_ID must be set explicitly so campaigns are not created in
# the wrong account. Use 1099427521 when repurposing the existing promo account.
GOOGLE_ADS_MANAGER_CUSTOMER_ID=2496704694
GOOGLE_ADS_CUSTOMER_ID=1099427521
GOOGLE_ADS_CONFIG_PATH=/Users/duncananderson/.codex/google-ads.yaml
GOOGLE_ADS_DAILY_BUDGET_CAD=20.00
GOOGLE_ADS_MAX_CPC_CAD=3.00
GOOGLE_ADS_EXPANDED_MAX_CPC_CAD=6.00
GOOGLE_ADS_AI_CONSULTING_LANDING_URL=https://www.duncananderson.ca/en/ai-workflow-audit

# Public Google tag / Google Ads conversion tracking. The send_to value usually
# has the shape AW-XXXXXXXXXX/YYYYYYYYYYYYYYYYYYY.
NEXT_PUBLIC_GOOGLE_TAG_ID=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CONVERSION_SEND_TO=

# --- Client portal (/portal/*) ---
# Random 32+ char hex string used to sign session cookies. Generate with:
#   openssl rand -hex 32
PORTAL_SESSION_SECRET=

# Either set PORTAL_USERS as a JSON array of {username,password,client}.
# Use client "admin" for Duncan's private admin tools.
# PORTAL_USERS=[{"username":"duncan","password":"...","client":"admin"},{"username":"gabby","password":"...","client":"ttg"},{"username":"alex","password":"...","client":"alex"}]
# Or use the simple single-user fallback (creates a "ttg" user with this password):
PORTAL_PASSWORD=
# Optional local fallback for Duncan's admin dashboard. Username is "duncan".
ADMIN_PORTAL_PASSWORD=
# Enable server-side admin lead scans outside local development.
# Production scans also require BLOB_READ_WRITE_TOKEN so the portal can publish results.
LEAD_SCAN_ENABLED=
# Created by linking the private Vercel Blob store used by the admin leads page.
BLOB_READ_WRITE_TOKEN=

# --- Admin lead generator database (Supabase) ---
SUPABASE_URL=https://your-project-ref.supabase.co
# Backend-only. Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
# Optional browser-safe key for future client-side read-only flows.
SUPABASE_PUBLISHABLE_KEY=

# --- Alex Parker portal prototypes (/portal/alex) ---
# Backend-only. Used for receipt/invoice/field-note extraction.
OPENAI_API_KEY=
# Optional. Enables sandbox-only "Create sandbox review item" writes.
AIRTABLE_API_KEY=
ALEX_SANDBOX_AIRTABLE_BASE_ID=appRB4L3wVfpN9tIb
ALEX_GMAIL_REVIEW_QUEUE_TABLE_ID=tblcN2NELRJKSD2G2

# --- Reddit API collection (admin lead generator) ---
# Create/register a Reddit app and use OAuth-backed requests instead of RSS.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="DuncanAndersonLeadMonitor/0.2 (manual lead review; https://duncananderson.ca)"
# Optional if using script/password grant for a personal account.
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- TTG WordPress publishing (used by /portal/ttg/publish) ---
TTG_WP_BASE_URL=https://traumatherapygroup.com
TTG_WP_USERNAME=gabevans
TTG_WP_APP_PASSWORD=

# --- Google Gemini / Imagen 4 (used for blog image generation) ---
# Get a key at https://aistudio.google.com/app/apikey (billing must be enabled for Imagen)
GEMINI_API_KEY=
