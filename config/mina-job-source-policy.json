{
  "version": 2,
  "requiredLanes": ["canadian_market", "direct_ats"],
  "minimumCanadianMarketQuerySuccessRatio": 0.9,
  "minimumDirectAtsSuccessRatio": 0.8,
  "maxCanonicalResponseBytes": 1500000,
  "canonicalTimeoutMs": 8000,
  "notificationsDefault": false,
  "retentionDays": {
    "discoveryCandidateEvidence": 30,
    "sourceRuns": 90
  },
  "providers": {
    "jobBank": { "maximumQueriesPerRun": 4, "credential": null, "required": true },
    "brave": { "maximumQueriesPerRun": 20, "credential": "BRAVE_SEARCH_API_KEY" },
    "serpapi": { "maximumQueriesPerRun": 20, "credential": "SERPAPI_API_KEY", "fallbackOnly": true },
    "reddit": { "maximumQueriesPerRun": 4, "credential": "REDDIT_CLIENT_ID" },
    "adzuna": { "maximumQueriesPerRun": 9, "credential": "MINA_ADZUNA_APP_ID", "supplemental": true }
  }
}
