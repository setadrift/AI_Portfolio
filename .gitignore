# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Stale files from earlier exploration sessions (keep on disk for reference)
/wp_publish/
/wp_test_publish.py
/TTG_AI_Proposal.docx

# Python reference code (the production version is in TypeScript under src/)
/_python_reference/

# Local generated images during development
/generated_images/

# Worktree slots — created by .claude/scripts/setup-worktree.sh in sibling dirs.
# A stray copy may end up here from older configs; ignore it inside the repo.
/worktrees/

